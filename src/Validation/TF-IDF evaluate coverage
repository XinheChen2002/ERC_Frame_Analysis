# ========= Step 3: same-year TF-IDF top 5 =========
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity
import numpy as np
import pandas as pd

same_year_results = []
top_k = 10

years = ["2021", "2022", "2023", "2024"]
# unify year type
problems_long["year"] = problems_long["year"].astype(str)
strategies_long["year"] = strategies_long["year"].astype(str)

for year in years:
    # 只取当年的 problems 和 strategies
    year_problems = problems_long[problems_long["year"] == year].copy()
    year_strategies = strategies_long[strategies_long["year"] == year].copy()
    
    # 文本列表
    strategy_corpus = year_strategies["strategy_text_clean"].tolist()
    problem_queries = year_problems["query_text_clean"].tolist()

    # TF-IDF
    vectorizer = TfidfVectorizer(stop_words="english")
    strategy_matrix = vectorizer.fit_transform(strategy_corpus)
    problem_matrix = vectorizer.transform(problem_queries)
    
    similarity_matrix = cosine_similarity(problem_matrix, strategy_matrix)
    
    # 取 top k
    for i, problem_row in year_problems.reset_index(drop=True).iterrows():
        scores = similarity_matrix[i]
        top_indices = np.argsort(scores)[::-1][:top_k]
        
        for rank, idx in enumerate(top_indices, start=1):
            same_year_results.append({
                "problem_id": problem_row["problem_id"],
                "problem": problem_row["problem"],
                "query_text": problem_row["query_text"],
                "rank": rank,
                "strategy_id": year_strategies.iloc[idx]["strategy_id"],
                "strategy_text": year_strategies.iloc[idx]["strategy_text"],
                "tfidf_score": scores[idx],
                "problem_year": problem_row["year"],
                "strategy_year": year_strategies.iloc[idx]["year"]
            })


same_year_tfidf_results = pd.DataFrame(same_year_results)
same_year_tfidf_results["manual_relevance"] = ""
same_year_tfidf_results["notes"] = ""

print(same_year_tfidf_results.head(10))
print("\nshape:", same_year_tfidf_results.shape)

same_year_tfidf_results.to_csv("tfidf_top10_same_year_results.csv", index=False)
print("Saved: tfidf_top10_same_year_results.csv")
